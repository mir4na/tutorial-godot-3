theme_override_font_sizes/font_size = 18
text = "🎮  Kontrol:
    A / ←  →  D / →        =   Bergerak kiri / kanan
    W / ↑                        =   Lompat (2x untuk double jump)
    Space                        =   Jongkok
    Double-tap A/D      =   Dash

⭐  Tujuan:
    Tangkap logo fasilkom yang jatuh dari atas untuk mendapatkan point.
    Hindari meteor merah dari 3 arah (atas, kiri, kanan).

❤️  Nyawa:
    Player punya 3 nyawa.
    Terkena obstacle = Kurang 1 nyawa.
    Gagal menangkap object = Kurang 1 nyawa.
    Nyawa habis? tewas :v (game over)"

